{
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "dist",
    "scripts"
  ],
  "compilerOptions": {
    "lib": [
      "ES2024",
    ],
    "module": "nodenext",
    "target": "ES2024",
    // "rootDir": "./src",
    "rootDirs": [
      "./src",
      "./test"
    ],
    "outDir": "./dist",
    "types": [
      "node",
      "jest"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedSideEffectImports": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}
